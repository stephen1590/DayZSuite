{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Authenticated webhook API — bridges signed HTTP calls to allowlisted server actions (DayZ first).",
  "engines": { "node": ">=22" },
  "scripts": {
