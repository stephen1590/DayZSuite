meta {
  name: config
  type: http
  seq: 11
}

post {
  url: {{baseUrl}}/dayz/config?name=overrides
  body: none
  auth: none
}

params:query {
  name: overrides
}

docs {
  retrieve one allowlisted config file (read-only)
  
  Read-only, so query params are accepted (unsigned); a body param of the same name wins. Only names from /dayz/configs are readable, always from a path under the DayZ server dir, and well-known secret keys are redacted server-side.
}
