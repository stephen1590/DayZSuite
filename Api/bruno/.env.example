# Local credentials for the Bruno collection - copy to .env (gitignored) and fill in.
# Secrets live only here; the environment files (environments/*.bru) reference these
# via {{process.env.NAME}} and hold no secrets themselves.

# --- master (the "prod" environment signs with this) ---
# From the box: sudo cat /etc/api/secrets.env
HMAC_SECRET=
# Only needed for the dayz/sources/vpp request:
VPP_TOKEN=

# --- derived key (the "testing" environment signs with this) ---
# Mint one via the keys/create request (as the master), then paste the id + the
# secret it returns ONCE. Select the "testing" environment in Bruno to sign as this
# key (X-Key-Id is sent automatically); "prod" ignores these and uses the master.
API_KEY_ID=
API_KEY_SECRET=
