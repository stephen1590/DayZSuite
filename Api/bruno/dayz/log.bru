meta {
  name: log
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/dayz/log?lines=100&type=rpt
  body: none
  auth: none
}

params:query {
  lines: 100
  type: rpt
}

docs {
  Tail of the NEWEST DayZ server log. Query params (read-only actions accept them
  unsigned): lines 1-500 (default 100), type rpt|adm. `file` in the reply names
  which log was read - the RPT rotates on every server restart.
}
