# Shared per-HOST deploy config for the single Ubuntu box.
#
# Copy this to host.config.env and fill in real values. This is the ONE source
# of truth for domain + SSH details on this box. Every service loads it via the
# shared Load-DeployConfig.ps1 (merged under its deploy.config.json). Flat
# KEY=VALUE; blank lines and #-comments are ignored; quotes around a value are
# optional.
#
# KEY note on TLS: a DDNS *wildcard* (*.<BaseDomain>) only makes subdomains
# RESOLVE to this box. Certs are still issued per-name over HTTP-01 (a wildcard
# *certificate* would require DNS-01, which this setup does not use).

# --- The box ---
Server=myhost.example.com
SshUser=deploy
SshPort=22
# SshKey=~/.ssh/id_ed25519   # optional; omit for ssh defaults

# --- Domain (DDNS) ---
BaseDomain=yourname.ddns.net
AdminEmail=you@example.com
