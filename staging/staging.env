# Dev-machine-local staging VM config — the staging counterpart of DayZ-Server/deployer.env.
# KEY=VALUE, one per line; # comments and blanks ignored; optional quotes around values.
# Lives next to New-StagingVm.ps1, never leaves this machine. CLI params win over this
# file; the STAGING_VM_DIR process env var is the last fallback before built-in defaults.

STAGING_VM_DIR=/mnt/edd78196-2438-47c2-8a82-9aa53d232ab3/Virtual Machines/staging-vm

# Uncomment to override the script defaults:
# STAGING_VM_DISK_GB=80
# STAGING_VM_MEM_GB=8
# STAGING_VM_CPUS=4
# STAGING_UBUNTU_VERSION=24.04
