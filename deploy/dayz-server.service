[Unit]
Description=DayZ Dedicated Server
Wants=network-online.target
After=network-online.target

[Service]
# TEMPLATE: the DEPLOY_USER/GROUP/HOME placeholders below are rendered per-host by
# Deploy-DayZServer.ps1 from host.env — never install this file without substituting them.
User={{DEPLOY_USER}}
Group={{DEPLOY_GROUP}}
WorkingDirectory={{DEPLOY_HOME}}/servers/dayz-server/
# Map selection: edit DAYZ_MISSION in map.env, then restart. Do not delete map.env.
EnvironmentFile={{DEPLOY_HOME}}/servers/dayz-server/map.env
# prestart.sh = storage backup + character migration on map switch. Local file ops
# only — no steamcmd here (its login would bump the account's other Steam session;
# one session per account, Valve-side). update.sh is run by Deploy when mods are missing.
ExecStartPre={{DEPLOY_HOME}}/servers/dayz-server/prestart.sh
# The -mod chain is RENDERED from deploy/mods.conf ({{DEPLOY_MODLINE}}) — enable/disable/
# reorder mods THERE (line order = load order), then ./Deploy-DayZServer.ps1 -Fix.
# Never hand-edit a mod list here: it would drift from the registry on the next deploy.
#
# -serverMod loads OUR server-only mods (semicolon-separated), SERVER-ONLY — never advertised
# to or downloaded by clients — OUR artifacts (built by HEMTT, shipped by Deploy-DayZServer.ps1),
# NOT workshop items. So they live OUTSIDE mods.conf and the -mod chain, as fixed names here:
#   @custom_server_mods - ex-@aib_tracker: live AI positions for the map overlay
#                         (profiles/AI_Bandits/live_positions.json) + fresh-spawn flu buff
#   @transfer_spawn - relocates migrated characters to the new map's own spawn points on a
#                     map switch (reads profiles/transfer_spawn.json; see serverMods/TransferSpawn)
ExecStart={{DEPLOY_HOME}}/servers/dayz-server/DayZServer -config=serverDZ.cfg -mission=mpmissions/${DAYZ_MISSION} -port=2301 "-mod={{DEPLOY_MODLINE}}" -serverMod=@custom_server_mods -BEpath=battleye -profiles=profiles -dologs -adminlog -freezecheck
ExecReload=/bin/kill -s HUP $MAINPID
ExecStop=/bin/kill -s INT $MAINPID
# DayZ-Expansion's AI (eAIGroup::Save) LEAKS file descriptors — the process climbs
# ~600 fds/min and, capped at 100000, hit the ceiling in <3h (well inside the 6h
# messages.xml restart cycle). At the ceiling every file write fails with "Couldn't
# open file for writing" (storage_1/expansion/ai/*), degrading the live server.
# We can't patch the mod, but the ceiling is ours: 1048576 (the kernel fs.nr_open
# default max, no sysctl needed) gives ~28h of runway, so a 6h cycle finishes clean
# and the scheduled restart resets the count. Mitigation, not a leak fix — if the
# leak rate climbs, shorten the restart cadence or cut the eAI load.
LimitNOFILE=1048576
# 45m, not the usual couple: when an update is armed, prestart.sh runs steamcmd
# (game app + mods) INSIDE start, before the engine boots. That download must fit inside
# this window or systemd kills the start mid-update. prestart caps its own update at
# UPDATE_TIMEOUT=2400s (40m), so this stays safely above it. A normal (unarmed) boot
# returns in seconds and never approaches this.
TimeoutStartSec=2700
# always, not on-failure: messages.xml <shutdown> and VPP's restart both exit CLEANLY
# (0) — on-failure would leave the server down after every scheduled/admin restart.
Restart=always
RestartSec=10s

[Install]
WantedBy=multi-user.target
